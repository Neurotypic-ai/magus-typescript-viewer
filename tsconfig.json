{
  "extends": "@neurotypic-ai/typescript-config/config/tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "./"
  },
  "include": [
    "./scripts/**/*.ts",
    "eslint.config.ts",
    "prettier.config.ts",
    "src/**/*.ts",
    "src/**/*.vue",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "**/node_modules/**/*", "**/dist/**/*", "**/node_modules/.pnpm/**/*"]
}
