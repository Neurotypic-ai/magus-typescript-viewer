{
  "author": "",
  "bin": {
    "typescript-viewer": "dist/bin/typescript-viewer.js"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.0-r.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vue-flow/node-toolbar": "^1.1.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jscodeshift": "^17.3.0",
    "ora": "^9.3.0",
    "pinia": "^3.0.4",
    "read-pkg": "^10.1.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.30"
  },
  "description": "TypeScript codebase visualization tool",
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@neurotypic-ai/eslint-config": "workspace:*",
    "@neurotypic-ai/typescript-config": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^24.12.0",
    "@typescript-eslint/utils": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.1",
    "knip": "^6.0.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.6"
  },
  "keywords": [
    "typescript",
    "visualization",
    "dependency-graph",
    "analysis"
  ],
  "license": "ISC",
  "main": "dist/index.js",
  "name": "magus-typescript-viewer",
  "scripts": {
    "build": "pnpm typecheck && vite build && node ./esbuild.config.js",
    "build:packages": "pnpm -r --filter='./packages/*' build",
    "build:apps": "pnpm -r --filter='./apps/*' build",
    "dev": "sh -c 'pnpm dev:server & pnpm dev:ui; wait'",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/server/parsers src/server/cli src/client/utils src/client/graph/cluster vitest.config.ts eslint.config.js",
    "lint:fix": "eslint src/server/parsers src/server/cli src/client/utils src/client/graph/cluster vitest.config.ts eslint.config.js --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "clean:install": "pnpm clean && pnpm install",
    "prepare": "husky",
    "analyze": "node --import tsx src/server/bin/typescript-viewer.ts analyze",
    "dev:server": "nodemon --watch src/server --watch src/server.ts --watch src/server/db --exec 'tsx' src/server.ts",
    "dev:ui": "vite",
    "preview": "vite preview",
    "serve": "node --import tsx src/server/bin/typescript-viewer.ts serve",
    "knip": "knip"
  },
  "type": "module",
  "version": "1.0.0"
}
